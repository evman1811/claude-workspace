# ───────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your real values.
# Keep the filled-in .env private — never share or upload it.
# ───────────────────────────────────────────────────────────────

# --- Claude (the "brain": summaries + lead scoring) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- OpenAI Whisper (speech-to-text).
#     ONLY needed if you feed in AUDIO files. Skip it if you feed in transcripts. ---
OPENAI_API_KEY=sk-...

# --- Salesforce ---
SF_USERNAME=you@example.com
SF_PASSWORD=your_password
SF_SECURITY_TOKEN=your_security_token
# "login" = production, "test" = sandbox
SF_DOMAIN=login
# Optional: a custom number field on the Lead object to hold the 0-100 score.
SF_SCORE_FIELD=

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_JSON=google-service-account.json
GOOGLE_SHEET_ID=
MY_EMAIL=evman1811@gmail.com

# --- Scoring ---
HOT_THRESHOLD=70

# --- Team / central mode (watch_folder.py) ---
# The folder the watcher monitors. Point this at a SHARED folder your reps drop
# call files into — a synced OneDrive/SharePoint/Google Drive/Dropbox folder or
# a network drive all work. Example (Windows):
#   INCOMING_DIR=C:\Users\you\OneDrive\Call Drop
INCOMING_DIR=incoming
